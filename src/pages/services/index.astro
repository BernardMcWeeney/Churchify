---
// src/pages/services/index.astro — THE product page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<Layout title="What's Included — Churchify">
  <Header />

  <PageHeader
    title="The Complete Parish Website"
    tagline="Everything your parish needs online — designed, built, and managed for you. One product. One price."
  />

  <!-- Pricing Banner -->
  <section class="py-12 bg-secondary/50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto bg-card rounded-2xl border border-border p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          <p class="text-xs uppercase tracking-widest text-accent mb-3 font-medium">Simple Pricing</p>
          <h2 class="text-2xl font-serif font-bold mb-2">One product. One price. Everything included.</h2>
          <p class="text-muted-foreground">€2,000 once-off setup &middot; €500 per year ongoing &middot; First year: €2,500</p>
        </div>
        <a href="/contact" class="bg-primary text-primary-foreground px-8 py-4 rounded-xl font-semibold hover:bg-primary/90 transition-colors shrink-0">
          Get Started
        </a>
      </div>
    </div>
  </section>

  <!-- Feature Group 1: Daily Living Content -->
  <section class="py-16 bg-secondary/50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-accent mb-1 font-medium">Automatic Content</p>
            <h2 class="text-2xl font-serif font-bold">Living Liturgical Content</h2>
            <p class="text-muted-foreground">Rich, structured Catholic content refreshed daily — it keeps your site alive.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Feast of the Day</h3>
            <p class="text-muted-foreground text-sm">Feast name, liturgical colour, rank, season, Sunday/weekday cycle, and Liturgy of the Hours reference.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Daily Mass Readings</h3>
            <p class="text-muted-foreground text-sm">First Reading, Responsorial Psalm, Second Reading, Gospel Acclamation, Gospel — full text display with Sunday archive.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Saint of the Day</h3>
            <p class="text-muted-foreground text-sm">Daily saint profile to inspire and educate your community.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Today's Rosary</h3>
            <p class="text-muted-foreground text-sm">Automatically reflects the correct mysteries for the day with each mystery title displayed.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Sunday Homily Extracts</h3>
            <p class="text-muted-foreground text-sm">Weekly homily content to complement the Sunday readings and encourage spiritual reflection.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Group 2: Mass & Sacraments -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-accent mb-1 font-medium">Scheduling</p>
            <h2 class="text-2xl font-serif font-bold">Mass Times & Sacraments</h2>
            <p class="text-muted-foreground">Clear scheduling and sacrament information for your community.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Mass Times Management</h3>
            <p class="text-muted-foreground text-sm">Recurring schedules, one-off special Masses, Holy Day scheduling, multiple churches, livestream indicators, and location filters.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Sacraments Information Hub</h3>
            <p class="text-muted-foreground text-sm">Dedicated pages for Baptism, First Communion, Confirmation, Marriage, Reconciliation, and Anointing — with procedures, contacts, and forms.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Parish Calendar</h3>
            <p class="text-muted-foreground text-sm">Full digital calendar with event management, recurring events, liturgical feasts, parish group events, and category filters.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Prayer Library</h3>
            <p class="text-muted-foreground text-sm">Morning Prayer, Evening Prayer, Prayer of the Day, traditional Catholic prayers, and parish-specific prayers — organised and searchable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Group 3: Communication -->
  <section class="py-16 bg-secondary/50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-accent mb-1 font-medium">Stay Connected</p>
            <h2 class="text-2xl font-serif font-bold">Communication & Notices</h2>
            <p class="text-muted-foreground">Keep your parish informed with structured, easy-to-manage updates.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Parish Notices</h3>
            <p class="text-muted-foreground text-sm">Death notices, baptism notices, marriage notices, and general announcements — each with date, optional image, and archive system.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Bulletin Upload</h3>
            <p class="text-muted-foreground text-sm">Upload your weekly bulletin PDF in seconds. Automatic archiving and display of recent issues. Minimal clicks required.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Contact & Office</h3>
            <p class="text-muted-foreground text-sm">Contact form, parish office details, office hours, location map, and structured contact routing.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Social Media Integration</h3>
            <p class="text-muted-foreground text-sm">Links to parish social media accounts and embedded feeds to encourage digital engagement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Group 4: Parish Directory -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-accent mb-1 font-medium">Your Parish</p>
            <h2 class="text-2xl font-serif font-bold">Parish Directory</h2>
            <p class="text-muted-foreground">A permanent digital record for parishioners, visitors, and those overseas researching family roots.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Churches</h3>
            <p class="text-muted-foreground text-sm">Name, address, map, Mass times, and livestream link for each church.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Clergy & Staff</h3>
            <p class="text-muted-foreground text-sm">Priest profiles, contact information, and roles within the parish.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Parish Groups</h3>
            <p class="text-muted-foreground text-sm">Choir, prayer groups, committees, youth ministry, and more.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Schools</h3>
            <p class="text-muted-foreground text-sm">Parish school information and contact details.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Cemeteries</h3>
            <p class="text-muted-foreground text-sm">Cemetery details and location information.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Parish History</h3>
            <p class="text-muted-foreground text-sm">Timeline, historical records, photo gallery, and parish life showcase.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Group 5: Engagement -->
  <section class="py-16 bg-secondary/50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-accent mb-1 font-medium">Engagement</p>
            <h2 class="text-2xl font-serif font-bold">Donations & Livestream</h2>
            <p class="text-muted-foreground">Accept online giving and broadcast Mass to those who can't attend in person.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Online Donations</h3>
            <p class="text-muted-foreground text-sm">Integrated with Stripe for secure one-off and recurring donations. Fully compliant with transparent processing. Terms & donation policies provided.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Livestream Integration</h3>
            <p class="text-muted-foreground text-sm">Embedded player supporting YouTube, ChurchServices.tv, or other providers. Visible broadcast schedule and archive option.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Group 6: Technical / Managed -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-accent mb-1 font-medium">Managed For You</p>
            <h2 class="text-2xl font-serif font-bold">Fully Managed Service</h2>
            <p class="text-muted-foreground">We handle everything technical so your parish doesn't have to.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Hosting & DNS</h3>
            <p class="text-muted-foreground text-sm">Fast, reliable hosting with domain management and SSL certificates.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Security & Backups</h3>
            <p class="text-muted-foreground text-sm">Security hardening, regular backups, and monitoring included.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Updates & Maintenance</h3>
            <p class="text-muted-foreground text-sm">WordPress core, plugin updates, and performance optimisation handled for you.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">WordPress Editor</h3>
            <p class="text-muted-foreground text-sm">Edit pages, publish posts, update notices, add events, and upload bulletins through an intuitive interface.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Training & Docs</h3>
            <p class="text-muted-foreground text-sm">Full training, documentation, guides, and ongoing support provided.</p>
          </div>
          <div class="bg-card rounded-2xl border border-border p-6">
            <h3 class="font-serif font-bold mb-2">Modern Design</h3>
            <p class="text-muted-foreground text-sm">Mobile-first, fast performance, accessibility compliant. Contemporary and welcoming for all generations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-secondary/50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-xs uppercase tracking-widest text-accent mb-3 font-medium">Getting Started</p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold mb-4">How It Works</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto text-lg">Three simple steps to your new parish website.</p>
      </div>

      <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">1</div>
          <h3 class="text-lg font-serif font-bold mb-2">We Talk</h3>
          <p class="text-muted-foreground">Tell us about your parish, your needs, and your vision. We'll guide you through everything.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">2</div>
          <h3 class="text-lg font-serif font-bold mb-2">We Build</h3>
          <p class="text-muted-foreground">We design, build, and set up your complete parish website with all your content.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6">3</div>
          <h3 class="text-lg font-serif font-bold mb-2">You're Live</h3>
          <p class="text-muted-foreground">Your parish goes online. We train your team and provide ongoing support and management.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/cat2-christ-church-cathedral.webp" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-primary/90"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
      <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-white">Ready to Get Your Parish Online?</h2>
      <p class="text-xl mb-10 max-w-2xl mx-auto text-white/80">€2,000 setup. €500 per year. Design, build, hosting, security, updates and support — everything included.</p>
      <a href="/contact" class="bg-accent text-foreground px-10 py-4 rounded-xl font-semibold shadow-lg transition-all duration-300 hover:bg-accent/90 hover:shadow-xl inline-block">
        Get Your Parish Online
      </a>
    </div>
  </section>

  <Footer />
</Layout>
