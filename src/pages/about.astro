---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHeader from '../components/PageHeader.astro';
import Values from '../components/about/Values.astro';
import Mission from '../components/about/Mission.astro';
import Story from '../components/about/Story.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About — Churchify">
  <Header />

  <PageHeader
    title="About Churchify"
    tagline="Building the modern parish website. One product, one mission."
  />

  <Story />

  <Mission />

  <Values />

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-br from-brand-800 via-brand-900 to-brand-950 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(255,255,255,0.05)_0%,_transparent_60%)]"></div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6 text-white">Ready to Work With Us?</h2>
      <p class="text-xl mb-10 max-w-3xl mx-auto text-white/80 leading-relaxed">Let's discuss how Churchify can give your parish a modern online home.</p>
      <a href="/contact" class="bg-white text-brand-800 px-8 py-4 rounded-2xl font-semibold shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300 inline-block">Contact Our Team</a>
    </div>
  </section>

  <Footer />
</Layout>
