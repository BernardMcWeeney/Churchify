---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHeader from '../components/PageHeader.astro';
import Values from '../components/about/Values.astro';
import Mission from '../components/about/Mission.astro';
import Story from '../components/about/Story.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About — Churchify">
  <Header />

  <PageHeader
    title="About Churchify"
    tagline="One product. One audience. One promise. We build the modern parish website."
  />

  <Story />

  <Mission />

  <Values />

  <!-- CTA Section -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/st-patricks-cathedral.webp" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-primary/90"></div>
    </div>
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
      <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-white">Ready to Give Your Parish a Modern Home Online?</h2>
      <p class="text-xl mb-10 max-w-3xl mx-auto text-white/80 leading-relaxed">€2,000 setup. €500 per year. Everything included.</p>
      <a href="/contact" class="bg-accent text-foreground px-8 py-4 rounded-xl font-semibold shadow-lg hover:bg-accent/90 hover:shadow-xl transition-all duration-300 inline-block">Contact Our Team</a>
    </div>
  </section>

  <Footer />
</Layout>
