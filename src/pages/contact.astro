---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Churchify">
  <Header />

  <PageHeader
    title="Get in Touch"
    tagline="Ready to bring your parish online? We'd love to hear from you."
  />

  <!-- Contact Section -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 max-w-5xl mx-auto">
        <!-- Contact Form -->
        <div class="lg:w-2/3 bg-card rounded-2xl p-8 md:p-10 border border-border">
          <h2 class="text-2xl font-serif font-semibold mb-2">Send Us a Message</h2>
          <p class="text-muted-foreground mb-8">Fill out the form below and we'll be in touch shortly.</p>
          <form id="contactForm" class="space-y-6" method="POST" action="/api/contact">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-muted-foreground font-medium mb-2 text-sm">Name</label>
                <input type="text" id="name" name="name" class="w-full px-4 py-3 border border-border rounded-xl focus:ring-2 focus:ring-ring focus:border-ring outline-none transition-colors bg-background text-foreground" placeholder="Your name" required>
              </div>
              <div>
                <label for="email" class="block text-muted-foreground font-medium mb-2 text-sm">Email</label>
                <input type="email" id="email" name="email" class="w-full px-4 py-3 border border-border rounded-xl focus:ring-2 focus:ring-ring focus:border-ring outline-none transition-colors bg-background text-foreground" placeholder="your.email@example.com" required>
              </div>
            </div>

            <div>
              <label for="parish" class="block text-muted-foreground font-medium mb-2 text-sm">Parish Name</label>
              <input type="text" id="parish" name="parish" class="w-full px-4 py-3 border border-border rounded-xl focus:ring-2 focus:ring-ring focus:border-ring outline-none transition-colors bg-background text-foreground" placeholder="Your parish name">
            </div>

            <div class="relative">
              <label for="subject" class="block text-muted-foreground font-medium mb-2 text-sm">Subject</label>
              <div class="relative">
                <select id="subject" name="subject" class="w-full px-4 py-3 border border-border rounded-xl focus:ring-2 focus:ring-ring focus:border-ring outline-none transition-colors appearance-none bg-background text-foreground" required>
                  <option value="" disabled selected>Select a subject</option>
                  <option value="New Parish Website">New Parish Website</option>
                  <option value="Question About Churchify">Question About Churchify</option>
                  <option value="Other">Other</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center px-3 pointer-events-none">
                  <svg class="w-5 h-5 text-muted-foreground" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label for="message" class="block text-muted-foreground font-medium mb-2 text-sm">Message</label>
              <textarea id="message" name="message" rows="5" class="w-full px-4 py-3 border border-border rounded-xl focus:ring-2 focus:ring-ring focus:border-ring outline-none transition-colors bg-background text-foreground" placeholder="Tell us about your parish and what you're looking for..." required></textarea>
            </div>

            <!-- Turnstile -->
            <div class="cf-turnstile" data-sitekey="0x4AAAAAAAWsI1fJREzBYF91" data-theme="light"></div>

            <div class="flex items-start">
              <input type="checkbox" id="consent" name="consent" class="mt-1 h-4 w-4 text-primary focus:ring-ring border-border rounded" required>
              <label for="consent" class="ml-3 block text-sm text-muted-foreground leading-relaxed">
                I consent to Churchify collecting and storing my data from this form. Your information will only be used to respond to your inquiry.
              </label>
            </div>

            <div>
              <button type="submit" id="submitBtn" class="bg-primary text-primary-foreground px-8 py-3 rounded-xl font-semibold hover:bg-primary/90 transition-colors">
                Send Message
              </button>
            </div>

            <!-- Status messages -->
            <div id="formSuccess" class="hidden p-4 bg-green-50 border border-green-200 rounded-xl text-green-800 text-sm">
              Thank you for your message! We'll be in touch shortly.
            </div>
            <div id="formError" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 text-sm">
              Something went wrong. Please try again or email us directly at info@churchify.ie.
            </div>
          </form>
        </div>

        <!-- Contact Information -->
        <div class="lg:w-1/3 space-y-6">
          <div class="bg-card rounded-2xl p-6 border border-border">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-serif font-semibold mb-1">Email</h3>
            <a href="mailto:info@churchify.ie" class="text-accent hover:text-accent/80 transition-colors text-sm">info@churchify.ie</a>
          </div>

          <div class="bg-card rounded-2xl p-6 border border-border">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-serif font-semibold mb-1">Location</h3>
            <p class="text-muted-foreground text-sm">County Meath, Ireland<br>Serving parishes nationwide</p>
          </div>

          <div class="bg-card rounded-2xl p-6 border border-border">
            <div class="w-11 h-11 bg-accent/10 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-serif font-semibold mb-1">Hours</h3>
            <p class="text-muted-foreground text-sm">Monday - Friday: 9am - 5pm</p>
          </div>

          <div class="bg-muted rounded-2xl p-6 border border-border">
            <h3 class="font-serif font-semibold mb-2">Quick Response</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">We respond to all inquiries within 24 hours. For urgent matters, mention it in your subject line.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const successMsg = document.getElementById('formSuccess');
    const errorMsg = document.getElementById('formError');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        successMsg?.classList.add('hidden');
        errorMsg?.classList.add('hidden');
        if (errorMsg) {
          errorMsg.textContent = 'Something went wrong. Please try again or email us directly at info@churchify.ie.';
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';

        try {
          const formData = new FormData(form);

          const response = await fetch('/api/contact', {
            method: 'POST',
            body: formData,
          });

          let result = { success: false, message: '' };
          const contentType = response.headers.get('content-type') || '';
          if (contentType.includes('application/json')) {
            result = await response.json();
          }

          if (response.ok && result.success) {
            successMsg?.classList.remove('hidden');
            form.reset();
          } else {
            if (errorMsg && result.message) {
              errorMsg.textContent = result.message;
            }
            errorMsg?.classList.remove('hidden');
          }
        } catch {
          errorMsg?.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      });
    }
  });
</script>
