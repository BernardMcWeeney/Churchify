---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — Churchify">
  <Header />

  <PageHeader
    title="Get in Touch"
    tagline="Ready to bring your parish online? We'd love to hear from you."
  />

  <!-- Contact Section -->
  <section class="py-24 bg-warm-50">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-12 max-w-5xl mx-auto">
        <!-- Contact Form -->
        <div class="lg:w-2/3 bg-white rounded-2xl p-8 md:p-10 border border-warm-200">
          <h2 class="text-2xl font-heading font-semibold mb-2 text-brand-800">Send Us a Message</h2>
          <p class="text-brand-800/60 mb-8">Fill out the form below and we'll be in touch shortly.</p>
          <form id="contactForm" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-brand-800/70 font-medium mb-2 text-sm">Name</label>
                <input type="text" id="name" name="name" class="w-full px-4 py-3 border border-warm-200 rounded-xl focus:ring-2 focus:ring-brand-300 focus:border-brand-300 outline-none transition-colors bg-white text-brand-800" placeholder="Your name" required>
              </div>
              <div>
                <label for="email" class="block text-brand-800/70 font-medium mb-2 text-sm">Email</label>
                <input type="email" id="email" name="email" class="w-full px-4 py-3 border border-warm-200 rounded-xl focus:ring-2 focus:ring-brand-300 focus:border-brand-300 outline-none transition-colors bg-white text-brand-800" placeholder="your.email@example.com" required>
              </div>
            </div>

            <div>
              <label for="parish" class="block text-brand-800/70 font-medium mb-2 text-sm">Parish Name</label>
              <input type="text" id="parish" name="parish" class="w-full px-4 py-3 border border-warm-200 rounded-xl focus:ring-2 focus:ring-brand-300 focus:border-brand-300 outline-none transition-colors bg-white text-brand-800" placeholder="Your parish name">
            </div>

            <div class="relative">
              <label for="subject" class="block text-brand-800/70 font-medium mb-2 text-sm">Subject</label>
              <div class="relative">
                <select id="subject" name="subject" class="w-full px-4 py-3 border border-warm-200 rounded-xl focus:ring-2 focus:ring-brand-300 focus:border-brand-300 outline-none transition-colors appearance-none bg-white text-brand-800" required>
                  <option value="" disabled selected>Select a subject</option>
                  <option value="New Parish Website">New Parish Website</option>
                  <option value="Question About Churchify">Question About Churchify</option>
                  <option value="Other">Other</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center px-3 pointer-events-none">
                  <svg class="w-5 h-5 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                </div>
              </div>
            </div>

            <div>
              <label for="message" class="block text-brand-800/70 font-medium mb-2 text-sm">Message</label>
              <textarea id="message" name="message" rows="5" class="w-full px-4 py-3 border border-warm-200 rounded-xl focus:ring-2 focus:ring-brand-300 focus:border-brand-300 outline-none transition-colors bg-white text-brand-800" placeholder="Tell us about your parish and what you're looking for..." required></textarea>
            </div>

            <!-- Turnstile -->
            <div class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY" data-theme="light"></div>

            <div class="flex items-start">
              <input type="checkbox" id="consent" name="consent" class="mt-1 h-4 w-4 text-brand-700 focus:ring-brand-300 border-warm-200 rounded" required>
              <label for="consent" class="ml-3 block text-sm text-brand-800/60 leading-relaxed">
                I consent to Churchify collecting and storing my data from this form. Your information will only be used to respond to your inquiry.
              </label>
            </div>

            <div>
              <button type="submit" class="bg-brand-700 text-white px-8 py-3 rounded-xl font-semibold hover:bg-brand-600 transition-all duration-300 shadow-sm hover:shadow-md">
                Send Message
              </button>
            </div>
          </form>
        </div>

        <!-- Contact Information -->
        <div class="lg:w-1/3 space-y-6">
          <div class="bg-white rounded-2xl p-6 border border-warm-200">
            <div class="w-11 h-11 bg-brand-50 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold mb-1 text-brand-800">Email</h3>
            <a href="mailto:info@churchify.ie" class="text-brand-700 hover:text-brand-600 transition-colors text-sm">info@churchify.ie</a>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-warm-200">
            <div class="w-11 h-11 bg-brand-50 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold mb-1 text-brand-800">Location</h3>
            <p class="text-brand-800/60 text-sm">County Meath, Ireland<br>Serving parishes nationwide</p>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-warm-200">
            <div class="w-11 h-11 bg-brand-50 rounded-xl flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold mb-1 text-brand-800">Hours</h3>
            <p class="text-brand-800/60 text-sm">Monday - Friday: 9am - 5pm</p>
          </div>

          <div class="bg-brand-50 rounded-2xl p-6 border border-brand-100">
            <h3 class="font-heading font-semibold mb-2 text-brand-800">Quick Response</h3>
            <p class="text-brand-800/60 text-sm leading-relaxed">We respond to all inquiries within 24 hours. For urgent matters, mention it in your subject line.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm');

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Thank you for your message! We will get back to you soon.');
        form.reset();
      });
    }
  });
</script>
