---
// src/components/Footer.astro
---

<footer class="bg-primary text-primary-foreground pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-serif font-bold text-primary-foreground flex items-center mb-4 tracking-tight">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 mr-2 text-accent">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          Churchify
        </a>
        <p class="text-primary-foreground/50 mb-6 text-sm leading-relaxed">The modern parish website platform. Beautiful, practical websites for Catholic parishes across Ireland.</p>
        <div class="flex space-x-4">
          <a href="#" class="text-primary-foreground/40 hover:text-accent transition-colors" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/>
            </svg>
          </a>
          <a href="#" class="text-primary-foreground/40 hover:text-accent transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="text-primary-foreground/40 hover:text-accent transition-colors" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-accent font-serif font-semibold mb-4 text-sm uppercase tracking-wider">Navigate</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-primary-foreground/50 hover:text-primary-foreground transition-colors text-sm">Home</a></li>
          <li><a href="/about" class="text-primary-foreground/50 hover:text-primary-foreground transition-colors text-sm">About</a></li>
          <li><a href="/services" class="text-primary-foreground/50 hover:text-primary-foreground transition-colors text-sm">Features</a></li>
          <li><a href="/parishes" class="text-primary-foreground/50 hover:text-primary-foreground transition-colors text-sm">Parishes</a></li>
          <li><a href="/contact" class="text-primary-foreground/50 hover:text-primary-foreground transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <!-- What's Included -->
      <div>
        <h4 class="text-accent font-serif font-semibold mb-4 text-sm uppercase tracking-wider">Platform</h4>
        <ul class="space-y-3">
          <li class="text-primary-foreground/50 text-sm">Living Liturgical Content</li>
          <li class="text-primary-foreground/50 text-sm">Mass Times Management</li>
          <li class="text-primary-foreground/50 text-sm">Parish Notices & Bulletin</li>
          <li class="text-primary-foreground/50 text-sm">Sacraments & Directory</li>
          <li class="text-primary-foreground/50 text-sm">Online Donations</li>
          <li class="text-primary-foreground/50 text-sm">Livestream Integration</li>
          <li class="text-primary-foreground/50 text-sm">Fully Managed Service</li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-accent font-serif font-semibold mb-4 text-sm uppercase tracking-wider">Contact</h4>
        <address class="not-italic space-y-3">
          <p class="flex items-start text-primary-foreground/50 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 mt-0.5 text-primary-foreground/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            info@churchify.ie
          </p>
          <p class="flex items-start text-primary-foreground/50 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 mt-0.5 text-primary-foreground/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            County Meath, Ireland
          </p>
          <p class="flex items-start text-primary-foreground/50 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 mt-0.5 text-primary-foreground/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Mon - Fri: 9am - 5pm
          </p>
        </address>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 text-center text-primary-foreground/30 text-xs">
      <p>&copy; {new Date().getFullYear()} Churchify. All rights reserved.</p>
    </div>
  </div>
</footer>
