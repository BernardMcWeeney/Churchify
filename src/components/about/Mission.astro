---
// src/components/about/Mission.astro
---

<section class="py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-serif font-bold mb-6">Our Mission</h2>
      <p class="text-muted-foreground text-xl mb-12 leading-relaxed">To give every parish a modern, living website — so they can focus on ministry, not technology.</p>

      <div class="bg-muted p-10 rounded-2xl border border-border max-w-2xl mx-auto">
        <p class="italic text-muted-foreground leading-relaxed text-lg">"We believe that every parish, regardless of size or budget, deserves a professional online presence. Churchify exists to make that simple, affordable, and stress-free."</p>
        <p class="mt-5 font-semibold text-foreground">— The Churchify Team</p>
      </div>
    </div>
  </div>
</section>

<!-- What We Do -->
<section class="py-24 bg-secondary/50">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-serif font-bold mb-4">What We Do</h2>
        <p class="text-muted-foreground text-lg leading-relaxed max-w-2xl mx-auto">Churchify does one thing exceptionally well.</p>
      </div>

      <div class="bg-card rounded-2xl border border-border p-10 md:p-14 text-center">
        <p class="text-2xl md:text-3xl font-serif font-bold leading-snug mb-6">We build and manage high-quality parish websites so parishes can focus on ministry, not technology.</p>
        <div class="flex flex-wrap justify-center gap-3 mt-8">
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Modern Design</span>
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Daily Content</span>
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Easy Administration</span>
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Reliable Hosting</span>
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Secure Donations</span>
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Livestream</span>
          <span class="text-xs bg-muted text-foreground px-4 py-2 rounded-full font-medium">Zero Technical Stress</span>
        </div>
      </div>
    </div>
  </div>
</section>
