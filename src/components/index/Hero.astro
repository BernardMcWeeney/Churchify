---
// src/components/index/Hero.astro
---

<section class="relative overflow-hidden py-24 md:py-36">
  <!-- Warm gradient background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-900 to-brand-950"></div>

    <!-- Subtle stained glass texture -->
    <div class="absolute inset-0 hidden md:grid md:grid-cols-6 md:grid-rows-3 opacity-30">
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
    </div>

    <div class="absolute inset-0 grid grid-cols-2 grid-rows-3 md:hidden opacity-30">
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
    </div>

    <!-- Soft radial glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(184,134,11,0.08)_0%,_transparent_70%)]"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-950/50 via-transparent to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="container relative z-10 mx-auto px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="w-12 h-px bg-gradient-to-r from-transparent via-brand-300/50 to-transparent mx-auto mb-8"></div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold mb-6 text-white/95 leading-tight tracking-tight">
        The Modern Parish Website
      </h1>
      <p class="text-lg md:text-xl mb-10 text-brand-200/70 leading-relaxed max-w-2xl mx-auto">
        Beautiful, practical websites built specifically for Catholic parishes. We handle everything so you can focus on ministry.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/services" class="bg-white/95 text-brand-800 px-8 py-4 rounded-lg font-semibold shadow-lg transition-all duration-300 hover:shadow-xl hover:bg-white text-center text-sm tracking-wide">
          See What's Included
        </a>
        <a href="/contact" class="bg-transparent border border-brand-300/30 text-brand-100 px-8 py-4 rounded-lg font-medium transition-all duration-300 hover:bg-white/5 hover:border-brand-300/50 text-center text-sm tracking-wide">
          Get in Touch
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-16 flex flex-col sm:flex-row justify-center items-center gap-8 text-brand-300/50 text-xs uppercase tracking-widest">
        <span class="flex items-center gap-2">
          <div class="w-1 h-1 rounded-full bg-brand-400/50"></div>
          Fully Managed
        </span>
        <span class="flex items-center gap-2">
          <div class="w-1 h-1 rounded-full bg-brand-400/50"></div>
          Daily Content
        </span>
        <span class="flex items-center gap-2">
          <div class="w-1 h-1 rounded-full bg-brand-400/50"></div>
          From €500/year
        </span>
      </div>
    </div>
  </div>
</section>
