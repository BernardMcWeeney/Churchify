---
// src/components/index/Hero.astro
---

<section class="relative pt-20 pb-20 lg:pt-32 lg:pb-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left — Copy -->
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 border border-accent/30 bg-accent/5 rounded-full">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span class="text-xs font-medium tracking-wide uppercase text-accent-foreground">Trusted by parishes across Ireland</span>
        </div>

        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight text-foreground">
          Beautiful Websites for <span class="text-accent">Catholic Parishes</span>
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-muted-foreground max-w-md">
          We build and manage high-quality parish websites so you can focus on ministry, not technology.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex items-center justify-center bg-primary text-primary-foreground hover:bg-primary/90 font-medium px-8 py-4 rounded-lg text-base transition-colors">
            Start Your Parish Site
            <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a href="/services" class="inline-flex items-center justify-center border border-border text-foreground hover:bg-secondary font-medium px-8 py-4 rounded-lg text-base transition-colors">
            See What's Included
          </a>
        </div>

        <!-- Trust stats -->
        <div class="mt-12 flex items-center gap-8">
          <div>
            <p class="font-serif text-2xl font-bold text-foreground">€2,000</p>
            <p class="text-xs text-muted-foreground mt-0.5">Once-off Setup</p>
          </div>
          <div class="h-8 w-px bg-border"></div>
          <div>
            <p class="font-serif text-2xl font-bold text-foreground">€500</p>
            <p class="text-xs text-muted-foreground mt-0.5">Per Year Ongoing</p>
          </div>
          <div class="h-8 w-px bg-border"></div>
          <div>
            <p class="font-serif text-2xl font-bold text-foreground">100%</p>
            <p class="text-xs text-muted-foreground mt-0.5">Fully Managed</p>
          </div>
        </div>
      </div>

      <!-- Right — Image -->
      <div class="relative">
        <div class="relative rounded-lg overflow-hidden shadow-2xl shadow-primary/10">
          <img
            src="/cat1-st-fin-barre-cork.webp"
            alt="Beautiful Catholic church interior with warm golden light through stained glass"
            class="w-full h-auto object-cover"
          />
          <div class="absolute inset-0 bg-accent/5"></div>
        </div>
        <!-- Floating card -->
        <div class="absolute -bottom-6 -left-6 bg-card border border-border rounded-lg p-5 shadow-lg hidden lg:block">
          <p class="font-serif text-sm font-semibold text-foreground">Duleek & Bellewstown Parish</p>
          <p class="text-xs text-muted-foreground mt-1">Website launched in 5 days</p>
          <div class="mt-2 flex gap-0.5">
            <svg class="h-3.5 w-3.5 fill-accent text-accent" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
