---
// src/components/index/TrustStrip.astro
---

<section class="py-16 border-y border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <p class="text-center text-xs font-medium tracking-widest uppercase text-muted-foreground mb-10">
      Trusted by parishes across Ireland
    </p>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 items-center">
      <div class="flex items-center justify-center">
        <p class="font-serif text-sm font-semibold text-muted-foreground/60 text-center leading-tight">St. Mary's<br>Drogheda</p>
      </div>
      <div class="flex items-center justify-center">
        <p class="font-serif text-sm font-semibold text-muted-foreground/60 text-center leading-tight">Duleek &<br>Bellewstown</p>
      </div>
      <div class="flex items-center justify-center">
        <p class="font-serif text-sm font-semibold text-muted-foreground/60 text-center leading-tight">Donore &<br>Rossnaree</p>
      </div>
      <div class="flex items-center justify-center">
        <p class="font-serif text-sm font-semibold text-muted-foreground/60 text-center leading-tight">Holy Family<br>Drogheda</p>
      </div>
      <div class="flex items-center justify-center">
        <p class="font-serif text-sm font-semibold text-muted-foreground/60 text-center leading-tight">Bohermeen<br>Parish</p>
      </div>
    </div>
  </div>
</section>
