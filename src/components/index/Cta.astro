---
// src/components/index/Cta.astro
---

<section class="py-20 md:py-28 relative overflow-hidden">
  <div class="absolute inset-0 z-0">
    <img src="/cat2-christ-church-cathedral.webp" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-primary/90"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6 text-white">Ready to Bring Your Parish Online?</h2>
    <p class="text-lg mb-10 max-w-2xl mx-auto text-white/80 leading-relaxed">Join parishes across Ireland who trust Churchify to power their modern online presence. €2,000 setup, then €500 per year.</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/contact" class="bg-accent text-foreground px-8 py-4 rounded-lg font-semibold shadow-lg transition-all duration-300 hover:bg-accent/90 hover:shadow-xl text-center">
        Get Your Parish Online
      </a>
      <a href="/services" class="border-2 border-white/40 text-white px-8 py-4 rounded-lg font-medium transition-all duration-300 hover:bg-white/10 hover:border-white/60 text-center">
        See What's Included
      </a>
    </div>
  </div>
</section>
