---
// src/components/index/Cta.astro
---

<section class="py-20 md:py-28 relative overflow-hidden">
  <!-- Warm gradient background with subtle texture -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-900 to-brand-950"></div>

    <div class="absolute inset-0 hidden md:grid md:grid-cols-4 md:grid-rows-2 opacity-25">
      <div class="stained-panel-red"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-purple"></div>
    </div>

    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(184,134,11,0.06)_0%,_transparent_70%)]"></div>
  </div>

  <div class="container mx-auto px-4 text-center relative z-10">
    <div class="w-12 h-px bg-gradient-to-r from-transparent via-brand-300/40 to-transparent mx-auto mb-8"></div>
    <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6 text-white/95">Ready to Bring Your Parish Online?</h2>
    <p class="text-lg mb-10 max-w-2xl mx-auto text-brand-200/60 leading-relaxed">Join parishes across Ireland who trust Churchify to power their online presence.</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <a href="/services" class="bg-white/95 text-brand-800 px-8 py-4 rounded-lg font-semibold shadow-lg transition-all duration-300 hover:shadow-xl hover:bg-white text-center text-sm tracking-wide">
        See What's Included
      </a>
      <a href="/contact" class="bg-transparent border border-brand-300/30 text-brand-100 px-8 py-4 rounded-lg font-medium transition-all duration-300 hover:bg-white/5 hover:border-brand-300/50 text-center text-sm tracking-wide">
        Contact Us
      </a>
    </div>
  </div>
</section>
