---
// src/components/PageHeader.astro
interface Props {
  title: string;
  tagline: string;
}

const { title, tagline } = Astro.props;
---

<section class="relative overflow-hidden py-24 md:py-32">
  <div class="absolute inset-0 z-0">
    <img src="/st-patricks-cathedral.webp" alt="" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-primary/90"></div>
  </div>

  <div class="mx-auto max-w-7xl relative z-10 px-6 lg:px-8 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold mb-6 text-white">{title}</h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto leading-relaxed text-white/80">{tagline}</p>
  </div>
</section>
