---
// src/components/PageHeader.astro
interface Props {
  title: string;
  tagline: string;
}

const { title, tagline } = Astro.props;
---

<section class="relative overflow-hidden py-24 md:py-32">
  <!-- Warm gradient background with subtle stained glass texture -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-900 to-brand-950"></div>

    <!-- Subtle stained glass panels — very low opacity for texture -->
    <div class="absolute inset-0 hidden md:grid md:grid-cols-6 md:grid-rows-2 opacity-40">
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
      <div class="stained-panel-purple"></div>
      <div class="stained-panel-red"></div>
      <div class="stained-panel-blue"></div>
      <div class="stained-panel-gold"></div>
    </div>

    <!-- Soft radial glow -->
    <div class="absolute inset-0 bg-gradient-to-t from-brand-950/60 via-transparent to-brand-800/30"></div>
  </div>

  <!-- Content -->
  <div class="container relative z-10 mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold mb-6 text-white/95 drop-shadow-sm">{title}</h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto leading-relaxed text-brand-200/80">{tagline}</p>
  </div>
</section>
